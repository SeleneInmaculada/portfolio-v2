---
import { useTranslations, getLangFromUrl, type Lang } from '../i18n/utils';

export interface Props {
  currentUrl: URL;
}

const { currentUrl } = Astro.props;
const lang: Lang = getLangFromUrl(currentUrl);
const t = useTranslations(lang);
const base = '/portfolio-selene';
---

<section class="section about" id="about">
  <div class="container">
    <h2 class="section-heading fade-in">{t.about.heading}</h2>
    <div class="about-grid">
      <div class="about-text fade-in-left">
        <p class="about-body">{t.about.body}</p>
        <div class="about-badges">
          <span class="badge"><i class="fas fa-map-marker-alt"></i> {t.about.location}</span>
          <span class="badge"><i class="fas fa-robot"></i> {t.about.badge_ai}</span>
          <span class="badge"><i class="fas fa-gamepad"></i> {t.about.badge_games}</span>
          <span class="badge"><i class="fas fa-code"></i> {t.about.badge_web}</span>
        </div>
        <a href={`${base}/CV_Selene_Garcia_Chacon.pdf`} download class="btn-primary cv-btn">
          <i class="fas fa-download"></i>
          {t.about.download_cv}
        </a>
      </div>
      <div class="about-stats fade-in-right">
        <div class="stat-card">
          <div class="stat-number">7+</div>
          <div class="stat-label">{lang === 'es' ? 'Proyectos' : 'Projects'}</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">4</div>
          <div class="stat-label">{lang === 'es' ? 'Titulaciones' : 'Degrees'}</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">4+</div>
          <div class="stat-label">{lang === 'es' ? 'Años de experiencia' : 'Years Experience'}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    position: relative;
  }

  .about::before {
    content: '';
    position: absolute;
    top: 10%;
    right: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.06) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .about-body {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 28px;
  }

  .about-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 28px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: var(--glass-bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--glass-border);
    border-radius: 50px;
    font-size: 0.85rem;
    color: var(--text-secondary);
    transition: var(--transition);
  }

  .badge:hover {
    border-color: rgba(139, 92, 246, 0.3);
    color: var(--text-primary);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(139, 92, 246, 0.15);
  }

  .badge i {
    color: var(--color-primary-bright);
  }

  .cv-btn {
    margin-top: 8px;
  }

  .about-stats {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .stat-card {
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    padding: 28px;
    text-align: center;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.03), rgba(34, 211, 238, 0.03));
    pointer-events: none;
  }

  .stat-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
    opacity: 0;
    transition: var(--transition);
  }

  .stat-card:hover {
    border-color: rgba(139, 92, 246, 0.25);
    transform: translateY(-6px);
    box-shadow: var(--shadow-glow-strong);
  }

  .stat-card:hover::after {
    opacity: 1;
  }

  .stat-number {
    font-size: 2.8rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--color-primary-bright), var(--color-accent), var(--color-pink));
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: statShimmer 4s ease-in-out infinite alternate;
    position: relative;
    z-index: 1;
  }

  @keyframes statShimmer {
    0%   { background-position: 0% 50%; }
    100% { background-position: 100% 50%; }
  }

  .stat-label {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 4px;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .about-stats {
      flex-direction: row;
    }

    .stat-card {
      flex: 1;
    }
  }

  @media (max-width: 480px) {
    .about-stats {
      flex-direction: column;
    }
  }
</style>
